# ═════════════════════════════════════════════════════════════════
# LIVEKIT CONFIGURATION
# ═════════════════════════════════════════════════════════════════
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# ═════════════════════════════════════════════════════════════════
# DATABASE CONFIGURATION
# Choose ONE: Supabase OR Self-Hosted Postgres
# ═════════════════════════════════════════════════════════════════

# OPTION 1: Supabase (for trials/free tier)
SUPABASE_REST_URL=
SUPABASE_API_KEY=

# OPTION 2: Self-Hosted Postgres (for production on EC2)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=agent_db
DB_USER=agent_user
DB_PASSWORD=change_me_in_production
DATABASE_URL=postgresql://agent_user:change_me_in_production@localhost:5432/agent_db

# ═════════════════════════════════════════════════════════════════
# AI PROVIDER KEYS (bring your own)
# ═════════════════════════════════════════════════════════════════
DEEPGRAM_API_KEY=
GEMINI_API_KEY=
SMALLEST_API_KEY=
GNANI_API_KEY=
SARVAM_API_KEY=

# ═════════════════════════════════════════════════════════════════
# TELEPHONY (Vobiz SIP)
# ═════════════════════════════════════════════════════════════════
VOBIZ_SIP_TRUNK_ID=
VOBIZ_SIP_DOMAIN=

# ═════════════════════════════════════════════════════════════════
# AUTOMATION (n8n)
# ═════════════════════════════════════════════════════════════════
N8N_WEBHOOK_URL=http://localhost:5678/webhook/agent
N8N_DB_NAME=n8n
N8N_HOST=localhost
N8N_PORT=5678
N8N_PROTOCOL=http

# ═════════════════════════════════════════════════════════════════
# AWS S3 (for database backups in production)
# ═════════════════════════════════════════════════════════════════
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BACKUP_BUCKET=agent-db-backups
AWS_DEFAULT_REGION=ap-south-1
